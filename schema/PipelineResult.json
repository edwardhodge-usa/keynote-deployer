{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PipelineResult",
  "description": "Full result of the process-and-deploy pipeline",
  "type": "object",
  "properties": {
    "success": {
      "type": "boolean"
    },
    "projectName": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "slideCount": {
      "type": "integer"
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "fixesApplied": {
      "type": "integer"
    },
    "fixesSkipped": {
      "type": "integer"
    },
    "error": {
      "type": "string"
    }
  },
  "required": ["success", "projectName", "title", "slideCount", "url", "fixesApplied", "fixesSkipped"]
}
